# ── Band ────────────────────────────────────────────────
BAND_API_KEY=your_band_api_key_here
BAND_ROOM_ID=your_band_room_id_here        # create a room at band.ai first

# ── AI/ML API (primary LLM — orchestrator, curator, study plan) ──
AIML_API_KEY=your_aiml_api_key_here        # from lablab.ai coupon
AIML_MODEL=claude-3-7-sonnet              # or gpt-4.1, gemini-2.0-flash

# ── Featherless AI (assessment agent — code analysis) ────
FEATHERLESS_API_KEY=your_featherless_key   # promo code: BOA26
FEATHERLESS_MODEL=deepseek-ai/DeepSeek-V2-Lite-Chat

# ── GitHub (repo scanning) ───────────────────────────────
GITHUB_TOKEN=your_github_token_here        # optional but avoids rate limits
